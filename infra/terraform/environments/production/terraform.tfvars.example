aws_region = "us-east-1"

# Frontend apps deployed from this monorepo (Vercel).
frontend_apps = {
  "storybook" = {
    root_directory = "apps/storybook"
  }
  "design-system-mcp" = {
    root_directory = "packages/mcp-server"
  }
}

# FastAPI backends are illustrative — replace with your own service(s).
fastapi_services = {
  "example-api" = {
    image_tag         = "latest"
    port              = 8000
    health_check_path = "/health"
    environment_variables = {
      APP_ENV = "production"
    }
  }
}
