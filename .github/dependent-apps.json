{
  "designSystemPackage": "@nikolayvalev/design-system",
  "apps": [
    {
      "id": "storybook",
      "path": "apps/storybook",
      "required": true
    },
    {
      "id": "command-panel",
      "path": "apps/command-panel",
      "required": true
    }
  ],
  "linkedRepositories": [
    {
      "id": "game",
      "role": "frontend",
      "repository": "https://github.com/NikolayValev/mandate-zero",
      "manifestPath": "app.manifest.json",
      "requiredManifest": false,
      "errorEnvelopeSamplePath": "contracts/examples/error-envelope.sample.json",
      "requiredErrorEnvelope": false
    },
    {
      "id": "second-brain-api",
      "role": "backend",
      "repository": "https://github.com/NikolayValev/SecondBrain",
      "manifestPath": "app.manifest.json",
      "requiredManifest": false,
      "openapiPath": "openapi/openapi.json",
      "openapiSnapshotPath": "openapi/second-brain.openapi.snapshot.json",
      "requiredOpenapi": false,
      "errorEnvelopeSamplePath": "contracts/examples/error-envelope.sample.json",
      "requiredErrorEnvelope": false
    },
    {
      "id": "second-brain-ui",
      "role": "frontend",
      "repository": "https://github.com/NikolayValev/second-brain-ui",
      "manifestPath": "app.manifest.json",
      "requiredManifest": false,
      "errorEnvelopeSamplePath": "contracts/examples/error-envelope.sample.json",
      "requiredErrorEnvelope": false
    },
    {
      "id": "strata",
      "role": "frontend",
      "repository": "https://github.com/NikolayValev/kami_times",
      "manifestUrl": "https://www.strategemalgo.com/app.manifest.json",
      "manifestPath": "app.manifest.json",
      "requiredManifest": false,
      "errorEnvelopeSampleUrl": "https://www.strategemalgo.com/contracts/examples/error-envelope.sample.json",
      "errorEnvelopeSamplePath": "contracts/examples/error-envelope.sample.json",
      "requiredErrorEnvelope": false
    }
  ]
}
