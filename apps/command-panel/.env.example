# Chat provider keys for the chat route (api/chat.ts). Server-side only — never
# exposed to the client bundle. Tests use a mock model and need neither.
#
# Provider selection (api/chat.ts), in priority order:
#   1. GITHUB_MODELS_TOKEN set → GitHub Models (FREE, OpenAI-compatible) using
#      GITHUB_MODELS_MODEL (default: openai/gpt-4o). Create a token with the
#      "models" permission at https://github.com/settings/personal-access-tokens
#   2. AI_GATEWAY_API_KEY set → Vercel AI Gateway using AI_GATEWAY_MODEL
#      (default: openai/gpt-4o). Requires a credit card on file to serve requests.
#   3. OPENROUTER_API_KEY set → OpenRouter (OpenAI-compatible) using
#      OPENROUTER_MODEL (default: openai/gpt-4o).
#   4. Otherwise → Anthropic via ANTHROPIC_API_KEY.
#
# Copy this file to .env (gitignored) and fill in a key. For local dev the Vite
# server loads .env into process.env automatically.

# GitHub Models (https://github.com/marketplace/models) — free with rate limits
GITHUB_MODELS_TOKEN=
# Optional — any GitHub Models id; defaults to openai/gpt-4o
GITHUB_MODELS_MODEL=openai/gpt-4o

# Vercel AI Gateway (https://vercel.com/ai-gateway) — used only if GITHUB_MODELS_TOKEN is unset
AI_GATEWAY_API_KEY=
# Optional — any gateway model id; defaults to openai/gpt-4o
AI_GATEWAY_MODEL=openai/gpt-4o

# OpenRouter (https://openrouter.ai/keys) — used only if the above are unset
OPENROUTER_API_KEY=
# Optional — any OpenRouter model id; defaults to openai/gpt-4o
OPENROUTER_MODEL=openai/gpt-4o

# Anthropic (https://console.anthropic.com) — used only if the above are unset
ANTHROPIC_API_KEY=
