# Chat provider keys for the chat route (api/chat.ts). Server-side only — never
# exposed to the client bundle. Tests use a mock model and need neither.
#
# Provider selection (api/chat.ts):
#   - If OPENROUTER_API_KEY is set, generation routes through OpenRouter
#     (OpenAI-compatible) using OPENROUTER_MODEL (default: openai/gpt-4o).
#   - Otherwise it falls back to Anthropic via ANTHROPIC_API_KEY.
#
# Copy this file to .env (gitignored) and fill in a key. For local dev the Vite
# server loads .env into process.env automatically.

# OpenRouter (https://openrouter.ai/keys)
OPENROUTER_API_KEY=
# Optional — any OpenRouter model id; defaults to openai/gpt-4o
OPENROUTER_MODEL=openai/gpt-4o

# Anthropic (https://console.anthropic.com) — used only if OPENROUTER_API_KEY is unset
ANTHROPIC_API_KEY=
